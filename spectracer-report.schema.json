{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "spectracer-report.schema.json",
    "title": "SpecTracerReport",
    "description": "Schema for a SpecTracer traceability report (the machine-readable twin of report.html).",
    "type": "object",
    "required": ["schemaVersion", "generatedAt", "config", "summary", "features"],
    "properties": {
        "schemaVersion": {
            "type": "string",
            "pattern": "^([0-9]+)(\\.(([1-9]\\d*)|0)){0,2}$",
            "description": "Version of this report format. Used for compatibility.",
            "examples": ["1", "1.0", "1.0.0"]
        },
        "generatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of when the report was generated."
        },
        "config": {
            "type": "object",
            "title": "ResolvedConfig",
            "description": "Verbatim echo of the resolved spectracer.config.json used to produce this report, for provenance when the JSON is archived independently of the repo state.",
            "required": ["features", "output"],
            "properties": {
                "features": {
                    "type": "array",
                    "items": { "type": "string" }
                },
                "unit": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "array",
                        "items": { "type": "string" }
                    }
                },
                "integration": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "array",
                        "items": { "type": "string" }
                    }
                },
                "e2e": {
                    "type": "array",
                    "items": { "type": "string" }
                },
                "output": { "type": "string" },
                "output_json": { "type": "string" },
                "error_on_failure": { "type": "boolean" },
                "health_checks": {
                    "type": "object",
                    "properties": {
                        "progress_threshold_green": { "type": "integer" },
                        "progress_threshold_amber": { "type": "integer" },
                        "e2e_duration_amber_seconds": { "type": "number" },
                        "e2e_duration_red_seconds": { "type": "number" }
                    }
                }
            }
        },
        "summary": {
            "type": "object",
            "title": "Summary",
            "required": ["coverage", "pyramid", "health"],
            "properties": {
                "coverage": {
                    "type": "object",
                    "title": "CoverageSummary",
                    "description": "The headline 'Tested: X / Y scenarios (Z%)' metric.",
                    "required": ["tested", "total", "percent"],
                    "properties": {
                        "tested": { "type": "integer", "minimum": 0 },
                        "total": { "type": "integer", "minimum": 0 },
                        "percent": { "type": "number", "minimum": 0, "maximum": 100 }
                    }
                },
                "pyramid": {
                    "type": "object",
                    "title": "PyramidSummary",
                    "description": "Per-layer test counts, duration, and pass rate.",
                    "properties": {
                        "unit": { "$ref": "#/definitions/layerStats" },
                        "integration": { "$ref": "#/definitions/layerStats" },
                        "e2e": { "$ref": "#/definitions/layerStats" }
                    }
                },
                "health": {
                    "type": "object",
                    "title": "HealthStatus",
                    "required": ["status", "reasons"],
                    "properties": {
                        "status": {
                            "type": "string",
                            "enum": ["green", "amber", "red"]
                        },
                        "reasons": {
                            "type": "array",
                            "description": "Human-readable explanations for the current status, e.g. 'inverted pyramid' or 'E2E duration exceeds red threshold'.",
                            "items": { "type": "string" }
                        }
                    }
                }
            }
        },
        "features": {
            "type": "array",
            "items": {
                "type": "object",
                "title": "FeatureResult",
                "required": ["name", "file", "scenarios"],
                "properties": {
                    "name": { "type": "string" },
                    "file": {
                        "type": "string",
                        "description": "Relative path to the .feature file."
                    },
                    "scenarios": {
                        "type": "array",
                        "items": { "$ref": "#/definitions/scenarioResult" }
                    }
                }
            }
        },
        "unlinkedTests": {
            "type": "array",
            "description": "Test results whose tags didn't match any scenario.",
            "items": {
                "type": "object",
                "required": ["layer", "testId", "name", "tags"],
                "properties": {
                    "layer": { "$ref": "#/definitions/layer" },
                    "module": {
                        "type": "string",
                        "description": "Module key this result was registered under, if any (unit/integration only)."
                    },
                    "testId": { "type": "string" },
                    "name": { "type": "string" },
                    "tags": {
                        "type": "array",
                        "items": { "type": "string" }
                    }
                }
            }
        }
    },
    "definitions": {
        "layer": {
            "type": "string",
            "enum": ["unit", "integration", "e2e"]
        },
        "layerStats": {
            "type": "object",
            "title": "LayerStats",
            "properties": {
                "testCount": { "type": "integer", "minimum": 0 },
                "duration": {
                    "type": "number",
                    "description": "Total duration for this layer in milliseconds."
                },
                "passRate": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 100
                }
            }
        },
        "scenarioResult": {
            "type": "object",
            "title": "ScenarioResult",
            "required": ["name", "tags", "requirements", "results"],
            "properties": {
                "name": { "type": "string" },
                "tags": {
                    "type": "array",
                    "description": "Linking tags on this scenario (e.g. @FC-42, @regression). Excludes @require-* tags.",
                    "items": { "type": "string" }
                },
                "requirements": {
                    "type": "array",
                    "description": "Declared @require-* layer requirements for this scenario and whether each is satisfied.",
                    "items": {
                        "type": "object",
                        "required": ["layer", "satisfied"],
                        "properties": {
                            "layer": { "$ref": "#/definitions/layer" },
                            "module": {
                                "type": "string",
                                "description": "Present only for module-scoped requirements, e.g. @require-unit:auth."
                            },
                            "satisfied": {
                                "type": "boolean",
                                "description": "False if this declared requirement ended up with zero linked results."
                            }
                        }
                    }
                },
                "results": {
                    "type": "array",
                    "description": "All test results linked to this scenario across all layers.",
                    "items": {
                        "type": "object",
                        "required": ["layer", "testId", "name", "status"],
                        "properties": {
                            "layer": { "$ref": "#/definitions/layer" },
                            "module": {
                                "type": "string",
                                "description": "Module key this result was registered under, if any (unit/integration only)."
                            },
                            "testId": { "type": "string" },
                            "name": { "type": "string" },
                            "status": {
                                "type": "string",
                                "enum": ["passed", "failed", "skipped"]
                            },
                            "duration": {
                                "type": "number",
                                "description": "Duration in milliseconds, if reported by the underlying test result."
                            },
                            "failureMessage": {
                                "type": "string",
                                "description": "Full failure message/stack trace, present only when status is 'failed'."
                            }
                        }
                    }
                }
            }
        }
    }
}
